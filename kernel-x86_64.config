# ═════════════════════════════════════════════════════════════════════════════
# Linux-libre 7.1.3 — x86_64 super minimal cloud kernel
# Target: headless QEMU q35, serial console (ttyS0), virtio-pci, ext4
# No modules, no debug, no firmware, no bloat, minimal PCI, no ACPI
# ═════════════════════════════════════════════════════════════════════════════

# ── General setup ──────────────────────────────────────────────────────────
CONFIG_LOCALVERSION="-linux-libre"
CONFIG_DEFAULT_HOSTNAME="linux-libre"
CONFIG_SWAP=n
CONFIG_SYSVIPC=n
CONFIG_POSIX_MQUEUE=n
CONFIG_CROSS_MEMORY_ATTACH=n
CONFIG_USELIB=n
CONFIG_AUDIT=n
CONFIG_IKCONFIG=n
CONFIG_IKHEADERS=n
CONFIG_LOG_BUF_SHIFT=12
CONFIG_PRINTK=y
CONFIG_PRINTK_NMI=n
CONFIG_BOOT_PRINTK_DELAY=n
CONFIG_EMBEDDED=y

# ── CPU/Task tuning ───────────────────────────────────────────────────────
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=n
CONFIG_NR_CPUS=1
CONFIG_SCHED_MC=n
CONFIG_SCHED_SMT=n
CONFIG_PREEMPT_NONE=y
CONFIG_HZ_100=y
CONFIG_HZ=100
CONFIG_BPF_SYSCALL=n
CONFIG_USERMODE_LINUX=n
CONFIG_COMPAT_32BIT_TIME=n

# ── Executable formats ────────────────────────────────────────────────────
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_BINFMT_MISC=n

# ── Memory management ─────────────────────────────────────────────────────
CONFIG_MEMCG=n
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_CLEANCACHE=n
CONFIG_FRONTSWAP=n
CONFIG_ZSWAP=n
CONFIG_ZPOOL=n
CONFIG_ZSMALLOC=n
CONFIG_BALLOON_COMPACTION=n

# ── Networking ────────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IP_MULTICAST=n
CONFIG_IP_ADVANCED_ROUTER=n
CONFIG_IP_PNP=n
CONFIG_SYN_COOKIES=n
CONFIG_NET_IP_TUNNEL=n
CONFIG_NET_FOU=n
CONFIG_INET_AH=n
CONFIG_INET_ESP=n
CONFIG_INET_IPCOMP=n
CONFIG_INET_DIAG=n
CONFIG_TCP_CONG_ADVANCED=n
CONFIG_TCP_CONG_CUBIC=y
CONFIG_DEFAULT_CUBIC=y
CONFIG_IPV6=n
CONFIG_NETFILTER=n
CONFIG_BRIDGE=n
CONFIG_WIRELESS=n
CONFIG_WEXT_CORE=n

# ── Device tree — not needed on x86 with PCI virtio ─────────────────────
# CONFIG_OF is not set

# ── Block layer ───────────────────────────────────────────────────────────
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_BSG=n
CONFIG_BLK_DEBUG_FS=n
CONFIG_PARTITION_ADVANCED=n
CONFIG_MSDOS_PARTITION=y
CONFIG_EFI_PARTITION=n

# ── PCI — minimal support for QEMU q35 with virtio-pci ─────────────────
# No hotplug, no AER, no MSI, no IOMMU
CONFIG_PCI=y
# CONFIG_DMI is not set

# ── No paravirt / KVM host — bare-metal guest ─────────────────────────────
CONFIG_VIRTUALIZATION=n
CONFIG_KVM=n
CONFIG_KVM_INTEL=n
CONFIG_KVM_AMD=n
CONFIG_KVM_GUEST=n
CONFIG_PARAVIRT=n
CONFIG_PARAVIRT_SPINLOCKS=n

# ── Device drivers ────────────────────────────────────────────────────────
# Serial — 8250 UART (ttyS0 for QEMU)
CONFIG_TTY=y
CONFIG_SERIAL_EARLYCON=n
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_NR_UARTS=1
CONFIG_SERIAL_8250_RUNTIME_UARTS=1
CONFIG_SERIAL_8250_DW=n
CONFIG_SERIAL_CORE=y
CONFIG_SERIAL_CORE_CONSOLE=y
CONFIG_SERIAL_NONSTANDARD=n
CONFIG_HVC_DRIVER=n
CONFIG_HVC_IRQ=n
CONFIG_HVC_XEN=n

# Virtio
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_NET_VENDOR_3COM=n
CONFIG_NET_VENDOR_ADAPTEC=n
CONFIG_NET_VENDOR_AGERE=n
CONFIG_NET_VENDOR_ALACRITECH=n
CONFIG_NET_VENDOR_AMAZON=n
CONFIG_NET_VENDOR_AMD=n
CONFIG_NET_VENDOR_AQUANTIA=n
CONFIG_NET_VENDOR_ARC=n
CONFIG_NET_VENDOR_ASIX=n
CONFIG_NET_VENDOR_ATHEROS=n
CONFIG_NET_VENDOR_BROADCOM=n
CONFIG_NET_VENDOR_BROCADE=n
CONFIG_NET_VENDOR_CADENCE=n
CONFIG_NET_VENDOR_CAVIUM=n
CONFIG_NET_VENDOR_CHELSIO=n
CONFIG_NET_VENDOR_CISCO=n
CONFIG_NET_VENDOR_CORTINA=n
CONFIG_NET_VENDOR_DAVICOM=n
CONFIG_NET_VENDOR_DEC=n
CONFIG_NET_VENDOR_DLINK=n
CONFIG_NET_VENDOR_EMULEX=n
CONFIG_NET_VENDOR_ENGLEDER=n
CONFIG_NET_VENDOR_EZCHIP=n
CONFIG_NET_VENDOR_FUNGIBLE=n
CONFIG_NET_VENDOR_GOOGLE=n
CONFIG_NET_VENDOR_HISILICON=n
CONFIG_NET_VENDOR_HUAWEI=n
CONFIG_NET_VENDOR_I825XX=n
CONFIG_NET_VENDOR_INTEL=n
CONFIG_NET_VENDOR_LITEX=n
CONFIG_NET_VENDOR_MARVELL=n
CONFIG_NET_VENDOR_MELLANOX=n
CONFIG_NET_VENDOR_META=n
CONFIG_NET_VENDOR_MICREL=n
CONFIG_NET_VENDOR_MICROCHIP=n
CONFIG_NET_VENDOR_MICROSEMI=n
CONFIG_NET_VENDOR_MICROSOFT=n
CONFIG_NET_VENDOR_MUCSE=n
CONFIG_NET_VENDOR_MYRI=n
CONFIG_NET_VENDOR_NATSEMI=n
CONFIG_NET_VENDOR_NETRONOME=n
CONFIG_NET_VENDOR_NI=n
CONFIG_NET_VENDOR_NVIDIA=n
CONFIG_NET_VENDOR_OKI=n
CONFIG_NET_VENDOR_PENSANDO=n
CONFIG_NET_VENDOR_QLOGIC=n
CONFIG_NET_VENDOR_QUALCOMM=n
CONFIG_NET_VENDOR_RDC=n
CONFIG_NET_VENDOR_REALTEK=n
CONFIG_NET_VENDOR_RENESAS=n
CONFIG_NET_VENDOR_ROCKER=n
CONFIG_NET_VENDOR_SAMSUNG=n
CONFIG_NET_VENDOR_SEEQ=n
CONFIG_NET_VENDOR_SILAN=n
CONFIG_NET_VENDOR_SIS=n
CONFIG_NET_VENDOR_SMSC=n
CONFIG_NET_VENDOR_SOCIONEXT=n
CONFIG_NET_VENDOR_SOLARFLARE=n
CONFIG_NET_VENDOR_STMICRO=n
CONFIG_NET_VENDOR_SUN=n
CONFIG_NET_VENDOR_SYNOPSYS=n
CONFIG_NET_VENDOR_TEHUTI=n
CONFIG_NET_VENDOR_TI=n
CONFIG_NET_VENDOR_VERTEXCOM=n
CONFIG_NET_VENDOR_VIA=n
CONFIG_NET_VENDOR_WANGXUN=n
CONFIG_NET_VENDOR_WIZNET=n
CONFIG_NET_VENDOR_XILINX=n
CONFIG_NET_VENDOR_8390=n
CONFIG_VIRTIO_BALLOON=n
CONFIG_VIRTIO_INPUT=n
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_NETDEVICES=y
CONFIG_ETHERNET=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=n
CONFIG_VIRTIO_ANCHOR=y

# Block
CONFIG_BLK_DEV_RAM=n
CONFIG_BLK_DEV_LOOP=n
CONFIG_BLK_DEV_NBD=n
CONFIG_CDROM=n
CONFIG_ATA=n

# Input — no keyboard/mouse in headless VM
CONFIG_INPUT=n
CONFIG_INPUT_KEYBOARD=n
CONFIG_INPUT_MOUSE=n
CONFIG_INPUT_MISC=n
CONFIG_INPUT_SERIO=n
CONFIG_VT=n
CONFIG_UNIX98_PTYS=n
CONFIG_LEGACY_PTYS=n

# HID / USB / Firewire / Sound — all off
CONFIG_HID=n
CONFIG_USB=n
CONFIG_USB_SUPPORT=n
CONFIG_SOUND=n
CONFIG_FIREWIRE=n

# Graphics / DRM — off (headless)
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_VGASTATE=n
CONFIG_VGA_CONSOLE=n
CONFIG_DUMMY_CONSOLE=n
CONFIG_AGP=n

# ACPI — not needed on QEMU microvm (no PCI, DT-based)
CONFIG_ACPI=n

# ── Filesystems ───────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_EXT4_FS_POSIX_ACL=n
CONFIG_EXT4_FS_SECURITY=n
CONFIG_JBD2=y
CONFIG_PROC_FS=y
CONFIG_PROC_KCORE=n
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=n
CONFIG_TMPFS_XATTR=n
CONFIG_RAMFS=y
CONFIG_CONFIGFS_FS=n
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# No other FS
CONFIG_NFS_FS=n
CONFIG_NFS_V4=n
CONFIG_CIFS=n
CONFIG_FUSE_FS=n
CONFIG_OVERLAY_FS=n
CONFIG_SQUASHFS=n
CONFIG_ECRYPT_FS=n
CONFIG_ISO9660_FS=n
CONFIG_MSDOS_FS=n
CONFIG_VFAT_FS=n
CONFIG_NTFS_FS=n
CONFIG_JFFS2_FS=n
CONFIG_UBIFS_FS=n

# ── Kernel features ───────────────────────────────────────────────────────
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_EPOLL=y
CONFIG_KCMP=n
CONFIG_RSEQ=y

# ── Boot options ──────────────────────────────────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_BZIP2=n
CONFIG_RD_LZMA=n
CONFIG_RD_XZ=n
CONFIG_RD_LZO=n
CONFIG_RD_LZ4=n
CONFIG_RD_ZSTD=n
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_OPTIMIZE_INLINING=y
CONFIG_KERNEL_GZIP=y
CONFIG_RANDOM_TRUST_CPU=y

# ── No CPU mitigations (safe on QEMU virtual CPU) ────────────────────────
CONFIG_MITIGATION_PAGE_TABLE_ISOLATION=n
CONFIG_MITIGATION_RETPOLINE=n
CONFIG_MITIGATION_RETHUNK=n
CONFIG_MITIGATION_SPECTRE_V1=n
CONFIG_MITIGATION_SPECTRE_V2=n
CONFIG_MITIGATION_SPECTRE_BHI=n
CONFIG_MITIGATION_GDS=n
CONFIG_MITIGATION_SRSO=n
CONFIG_MITIGATION_SLS=n
CONFIG_MITIGATION_MDS=n
CONFIG_MITIGATION_TAA=n
CONFIG_MITIGATION_MMIO_STALE_DATA=n
CONFIG_MITIGATION_L1TF=n
CONFIG_MITIGATION_RETBLEED=n
CONFIG_MITIGATION_SRBDS=n
CONFIG_MITIGATION_RFDS=n

# ── Subsystems not needed ────────────────────────────────────────────────
CONFIG_PPS=n
CONFIG_PTP_1588_CLOCK=n

# ── System calls ──────────────────────────────────────────────────────────
CONFIG_ARCH_HAS_SYSCALL_WRAPPER=n
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# ── Debug — all off ───────────────────────────────────────────────────────
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_PRINTK_TIME=n
CONFIG_DYNAMIC_DEBUG=n
CONFIG_FTRACE=n
CONFIG_STACKTRACE=n
CONFIG_DEBUG_BUGVERBOSE=n
CONFIG_EARLY_PRINTK=n
CONFIG_EARLY_PRINTK_DBGP=n
CONFIG_DEBUG_STACK_USAGE=n
CONFIG_DEBUG_KMEMLEAK=n
CONFIG_DEBUG_OBJECTS=n
CONFIG_DEBUG_SLAB=n
CONFIG_DEBUG_MUTEXES=n
CONFIG_DEBUG_SPINLOCK=n
CONFIG_DEBUG_ATOMIC_SLEEP=n
CONFIG_DEBUG_LIST=n
CONFIG_DEBUG_PLIST=n
CONFIG_DEBUG_SG=n
CONFIG_DEBUG_NOTIFIERS=n
CONFIG_DEBUG_CREDENTIALS=n
