	@echo "    arm64:   prefix='$(CROSS_arm64)'   sysroot=$(or $(SYSROOT_arm64),<host native>)"
	@echo ""
	@echo "═══ Other ═══"
	@echo "  make check-env             validate toolchain and submodules"
	@echo "  make prepare-sources       copy and patch all sources"
	@echo "  make prepare-sources-<pkg> copy and patch one package"
	@echo "  make clean                 remove build artifacts"
	@echo "  make distclean             clean + remove rootfs"
	@echo "  make LOG=1 <target>        tee output to build-logs/<target>.log"
	@echo "  make STRIP=0 install       skip binary stripping"
	@echo ""
	@echo "═══ Directories ═══"
	@echo "  sources/           git submodules (never modified)"
	@echo "  sources-patched/   patched source trees (copy + patches, once per pkg)"
