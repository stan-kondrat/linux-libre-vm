# ═════════════════════════════════════════════════════════════════════════════
# Linux-libre 7.1.3 — arm64 super minimal cloud kernel
# Target: headless QEMU virt, serial console (ttyAMA0), virtio, ext4, no IPv6
# No modules, no debug, no firmware, no bloat
# ═════════════════════════════════════════════════════════════════════════════

# ── General setup ──────────────────────────────────────────────────────────
CONFIG_LOCALVERSION="-linux-libre"
CONFIG_DEFAULT_HOSTNAME="linux-libre"
CONFIG_SWAP=n
CONFIG_SYSVIPC=n
CONFIG_POSIX_MQUEUE=n
CONFIG_CROSS_MEMORY_ATTACH=n
CONFIG_USELIB=n
CONFIG_AUDIT=n
CONFIG_IKCONFIG=n
CONFIG_IKHEADERS=n
CONFIG_LOG_BUF_SHIFT=14
CONFIG_PRINTK=y
CONFIG_BOOT_PRINTK_DELAY=n
CONFIG_EMBEDDED=y

# ── CPU/Task tuning ───────────────────────────────────────────────────────
CONFIG_ARM64=y
CONFIG_ARM64_4K_PAGES=y
CONFIG_ARM64_64K_PAGES=n
CONFIG_ARM64_VA_BITS_48=y
CONFIG_SCHED_MC=n
CONFIG_SMP=n
CONFIG_NR_CPUS=1
CONFIG_PREEMPT_NONE=y
CONFIG_HZ_250=y
CONFIG_HZ=250
CONFIG_BPF_SYSCALL=n
CONFIG_COMPAT=n
CONFIG_COMPAT_32BIT_TIME=n
CONFIG_ARM64_SVE=n
CONFIG_ARM64_SME=n
CONFIG_ARM64_BTI=n
CONFIG_ARM64_PA_BITS_48=y
CONFIG_ARM64_PA_BITS=48

# ── Executable formats ────────────────────────────────────────────────────
CONFIG_BINFMT_ELF=y
CONFIG_BINFMT_SCRIPT=y
CONFIG_BINFMT_MISC=n

# ── Memory management ─────────────────────────────────────────────────────
CONFIG_MEMCG=n
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_CLEANCACHE=n
CONFIG_FRONTSWAP=n
CONFIG_ZSWAP=n
CONFIG_ZPOOL=n
CONFIG_ZSMALLOC=n

# ── Networking ────────────────────────────────────────────────────────────
CONFIG_NET=y
CONFIG_PACKET=y
CONFIG_UNIX=y
CONFIG_INET=y
CONFIG_IP_PNP=n
CONFIG_SYN_COOKIES=n
CONFIG_IPV6=n
CONFIG_NETFILTER=n
CONFIG_BRIDGE=n
CONFIG_WIRELESS=n

# ── Block layer ───────────────────────────────────────────────────────────
CONFIG_BLK_DEV=y
CONFIG_BLK_DEV_BSG=n
CONFIG_PARTITION_ADVANCED=n
CONFIG_MSDOS_PARTITION=y
CONFIG_EFI_PARTITION=n

# ── PCI ───────────────────────────────────────────────────────────────────
CONFIG_PCI=y
CONFIG_PCI_MSI=y
CONFIG_PCI_LEGACY=n
CONFIG_PCIEASPM=n
CONFIG_PCI_IOV=n
CONFIG_PCI_HOST_GENERIC=y
CONFIG_HOTPLUG_PCI=n

# ── No KVM host — just a plain guest ──────────────────────────────────────
CONFIG_VIRTUALIZATION=n
CONFIG_KVM=n
CONFIG_KVM_ARM64=n
CONFIG_KVM_GENERIC_DIRTYLOG_READ_PROTECT=n

# ── Device drivers ────────────────────────────────────────────────────────
# Serial — PL011 (ttyAMA0) for QEMU virt machine
CONFIG_TTY=y
CONFIG_SERIAL_EARLYCON=n
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_SERIAL_NONSTANDARD=n
CONFIG_HVC_DRIVER=n
CONFIG_HVC_IRQ=n
CONFIG_HVC_VCUART=n

# ARM arch timers — needed by QEMU virt
CONFIG_ARM_ARCH_TIMER=y
CONFIG_ARM_ARCH_TIMER_EVTSTREAM=n

# GIC interrupt controller — needed by QEMU virt
CONFIG_ARM_GIC=y
CONFIG_ARM_GIC_V2M=y
CONFIG_ARM_GIC_V3=y
CONFIG_ARM_GIC_V3_ITS=n

# Virtio
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_PCI_LEGACY=n
CONFIG_VIRTIO_BALLOON=n
CONFIG_VIRTIO_INPUT=n
CONFIG_VIRTIO_MMIO=n
CONFIG_VIRTIO_BLK=y
CONFIG_NETDEVICES=y
CONFIG_ETHERNET=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=n
CONFIG_VIRTIO_ANCHOR=y

# Block
CONFIG_BLK_DEV_RAM=n
CONFIG_CDROM=n
CONFIG_ATA=n

# Input — no keyboard/mouse in headless VM
CONFIG_INPUT=n
CONFIG_INPUT_KEYBOARD=n
CONFIG_INPUT_MOUSE=n
CONFIG_INPUT_MISC=n
CONFIG_INPUT_SERIO=n
CONFIG_VT=n
CONFIG_UNIX98_PTYS=n
CONFIG_LEGACY_PTYS=n

# HID / USB / Sound — all off
CONFIG_HID=n
CONFIG_USB=n
CONFIG_USB_SUPPORT=n
CONFIG_SOUND=n

# Graphics / DRM — off (headless)
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_DUMMY_CONSOLE=n

# ACPI — not used by arm64 QEMU virt (uses DT)
CONFIG_ACPI=n

# ── Filesystems ───────────────────────────────────────────────────────────
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_EXT4_FS_POSIX_ACL=n
CONFIG_EXT4_FS_SECURITY=n
CONFIG_JBD2=y
CONFIG_PROC_FS=y
CONFIG_PROC_KCORE=n
CONFIG_PROC_SYSCTL=y
CONFIG_SYSFS=y
CONFIG_TMPFS=y
CONFIG_TMPFS_POSIX_ACL=n
CONFIG_TMPFS_XATTR=n
CONFIG_RAMFS=y
CONFIG_CONFIGFS_FS=n
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# No other FS
CONFIG_NFS_FS=n
CONFIG_CIFS=n
CONFIG_FUSE_FS=n
CONFIG_OVERLAY_FS=n
CONFIG_SQUASHFS=n
CONFIG_ISO9660_FS=n
CONFIG_VFAT_FS=n

# ── Kernel features ───────────────────────────────────────────────────────
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_EPOLL=y
CONFIG_RSEQ=y

# ── Boot options ──────────────────────────────────────────────────────────
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_BZIP2=n
CONFIG_RD_LZMA=n
CONFIG_RD_XZ=n
CONFIG_RD_LZO=n
CONFIG_RD_LZ4=n
CONFIG_RD_ZSTD=n
CONFIG_CC_OPTIMIZE_FOR_SIZE=y
CONFIG_OPTIMIZE_INLINING=y
CONFIG_KERNEL_GZIP=y
CONFIG_CMDLINE="console=ttyAMA0"
CONFIG_CMDLINE_FROM_BOOTLOADER=y

# ── System calls ──────────────────────────────────────────────────────────
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y

# ── Debug — all off ───────────────────────────────────────────────────────
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_PRINTK_TIME=n
CONFIG_DYNAMIC_DEBUG=n
CONFIG_FTRACE=n
CONFIG_STACKTRACE=n
CONFIG_DEBUG_BUGVERBOSE=n
CONFIG_DEBUG_STACK_USAGE=n
CONFIG_DEBUG_KMEMLEAK=n
CONFIG_DEBUG_OBJECTS=n
CONFIG_DEBUG_SLAB=n
CONFIG_DEBUG_MUTEXES=n
CONFIG_DEBUG_SPINLOCK=n
CONFIG_DEBUG_ATOMIC_SLEEP=n
CONFIG_DEBUG_LIST=n
CONFIG_DEBUG_PLIST=n
CONFIG_DEBUG_SG=n
CONFIG_DEBUG_NOTIFIERS=n
CONFIG_DEBUG_CREDENTIALS=n
