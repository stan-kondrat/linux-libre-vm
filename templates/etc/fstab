# /etc/fstab — static filesystem information

proc      /proc     proc     nosuid,noexec,nodev    0  0
sysfs     /sys      sysfs    nosuid,noexec,nodev    0  0
devtmpfs  /dev      devtmpfs nosuid,noexec,mode=0755 0  0
devpts    /dev/pts  devpts   nosuid,noexec,gid=5,mode=0620 0  0
tmpfs     /dev/shm  tmpfs    nosuid,noexec,nodev,mode=1777 0  0
tmpfs     /run      tmpfs    nosuid,noexec,nodev,mode=0755 0  0
