#!/bin/sh
# runit stage 3 — system shutdown
# All binaries are in /bin

PATH=/bin

echo "Shutting down services..."
sv -w196 force-stop /etc/service/* 2>/dev/null || true
sv exit /etc/service/* 2>/dev/null || true

echo "Unmounting filesystems..."
umount -a -r 2>/dev/null || true

if [ -f /etc/runit/reboot ]; then
  echo "Rebooting..."
  reboot -f
else
  echo "Powering off..."
  poweroff -f
fi
